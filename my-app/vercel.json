{
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": {
            "re": "^(?:www\\.expatsargentina\\.com|expatsargentina(?:-[^.]+)*\\.vercel\\.app)$"
          }
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
